    "settings.profile.launch.picker.detail": {
      "comment": "Explanation under 'Show picker' option",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Při každém spuštění aplikace vyberte, kdo se dívá."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg hvem der ser hver gang appen åbnes."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bei jedem App-Start auswählen, wer gerade schaut."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ποιος παρακολουθεί κάθε φορά που ανοίγει η εφαρμογή."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick who's watching every time the app opens."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige quién está viendo cada vez que se abre la app."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse kuka katselee aina, kun sovellus avataan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez qui regarde à chaque ouverture de l'app."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite tko gleda svaki put kad se aplikacija otvori."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd ki, ki nézi, valahányszor megnyílik az alkalmazás."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli chi sta guardando ogni volta che l'app viene aperta."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリを開くたびに視聴する人を選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "앱을 열 때마다 시청할 사람을 선택합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvem som ser på hver gang appen åpnes."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies wie er kijkt telkens wanneer de app wordt geopend."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz kto ogląda za każdym razem gdy aplikacja się otwiera."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quem está assistindo sempre que o app abrir."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quem está a ver sempre que a app abrir."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege cine se uită de fiecare dată când se deschide aplicația."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выбирайте, кто смотрит, при каждом запуске приложения."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte, kto sa pozerá pri každom spustení aplikácie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj vem som tittar varje gång appen öppnas."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama her açıldığında kimin izlediğini seç."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вибирайте, хто дивиться, щоразу під час відкриття застосунку."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每次打开应用时选择谁在观看。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每次開啟應用程式時選擇誰在觀看。"
          }
        }
      }
    },
