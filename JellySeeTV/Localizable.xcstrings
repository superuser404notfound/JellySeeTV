    "settings.appearance.locked.subtitle": {
      "comment": "Explainer on the locked Appearance screen",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odemkněte zvýrazňovací barvy spolu s prémiovou úvodní ikonou a odznakem podporovatele."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås op for fremhævningsfarver sammen med det premium splash-ikon og supporter-badget."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte die Akzentfarben zusammen mit dem Premium-Splash-Icon und dem Supporter-Abzeichen frei."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ξεκλειδώστε τα χρώματα έμφασης μαζί με το premium εικονίδιο έναρξης και το σήμα υποστηρικτή."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock accent colors along with the premium splash icon and supporter badge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea los colores de acento junto con el icono de inicio premium y la insignia de apoyo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa korostusvärit premium-käynnistyskuvakkeen ja tukija-merkin kanssa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloquez les couleurs d'accent avec l'icône de lancement premium et le badge de soutien."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Otključajte naglasne boje zajedno s premium uvodnom ikonom i podržavateljskom značkom."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Oldd fel a kiemelőszíneket a prémium nyitóikonnal és a támogatói jelvénnyel együtt."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca i colori di accento insieme all'icona iniziale premium e al badge sostenitore."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "プレミアムスプラッシュアイコンとサポーターバッジと一緒にアクセントカラーをアンロックします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "프리미엄 스플래시 아이콘 및 서포터 배지와 함께 강조 색상을 잠금 해제하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås opp aksentfarger sammen med premium splash-ikonet og supporter-merket."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel accentkleuren samen met het premium splash-icoon en de supportersbadge."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj kolory akcentu wraz z premiową ikoną powitalną i odznaką wspierającego."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie cores de destaque junto com o ícone de abertura premium e o distintivo de apoiador."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie cores de realce juntamente com o ícone de abertura premium e o distintivo de apoiante."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deblochează culorile de accent împreună cu pictograma de pornire premium și insigna de susținător."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разблокируйте акцентные цвета вместе с премиальной заставкой и значком поддержки."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Odomknite zvýrazňovacie farby spolu s prémiovou úvodnou ikonou a odznakom podporovateľa."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp accentfärger tillsammans med premium-startikonen och supporter-märket."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Premium açılış simgesi ve destekçi rozeti ile birlikte vurgu renklerinin kilidini açın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розблокуйте акцентні кольори разом із преміальною заставкою та значком прихильника."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解锁强调色以及高级启动图标和支持者徽章。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "解鎖強調色以及高級啟動圖示和支持者徽章。"
          }
        }
      }
    },
