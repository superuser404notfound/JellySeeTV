    "search.hint.connectSeerr": {
      "comment": "Hint shown under search.hint.startTyping when Seerr isn't connected yet",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Připoj Seerr v Nastavení, abys mohl prohledávat i katalog nových filmů a seriálů."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Forbind Seerr i Indstillinger for også at søge i kataloget efter nye film og serier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinde Seerr in den Einstellungen, um auch im Katalog nach neuen Filmen und Serien zu suchen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σύνδεσε το Seerr στις Ρυθμίσεις για να αναζητάς επίσης νέες ταινίες και σειρές στον κατάλογο."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect Seerr in Settings to also search the catalog for new movies and shows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta Seerr en Ajustes para buscar también en el catálogo nuevas películas y series."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yhdistä Seerr asetuksissa, jotta voit hakea myös luettelosta uusia elokuvia ja sarjoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connecte Seerr dans les Réglages pour rechercher aussi dans le catalogue de nouveaux films et séries."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Poveži Seerr u Postavkama kako bi pretraživao i katalog za nove filmove i serije."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csatlakoztasd a Seerr-t a Beállításokban, hogy a katalógusban is kereshess új filmeket és sorozatokat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Collega Seerr nelle Impostazioni per cercare anche nel catalogo nuovi film e serie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定で Seerr を接続すると、新しい映画や番組のカタログも検索できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정에서 Seerr를 연결하면 새 영화와 시리즈 카탈로그도 검색할 수 있습니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Koble til Seerr i Innstillinger for også å søke i katalogen etter nye filmer og serier."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbind Seerr in Instellingen om ook de catalogus te doorzoeken op nieuwe films en series."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz Seerr w Ustawieniach, aby przeszukiwać także katalog nowych filmów i seriali."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte o Seerr nos Ajustes para também pesquisar o catálogo por novos filmes e séries."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Liga o Seerr nas Definições para pesquisares também no catálogo novos filmes e séries."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectează Seerr în Setări pentru a căuta și în catalog filme și seriale noi."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключите Seerr в настройках, чтобы также искать новые фильмы и сериалы в каталоге."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pripoj Seerr v Nastaveniach, aby si mohol prehľadávať aj katalóg nových filmov a seriálov."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslut Seerr i Inställningar för att också söka i katalogen efter nya filmer och serier."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni filmler ve diziler için kataloğu da aramak üzere Ayarlar'dan Seerr'i bağla."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підключіть Seerr у Налаштуваннях, щоб також шукати нові фільми та серіали в каталозі."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置中连接 Seerr，即可在目录中搜索新电影和剧集。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在設定中連接 Seerr，即可在目錄中搜尋新電影和劇集。"
          }
        }
      }
    },
