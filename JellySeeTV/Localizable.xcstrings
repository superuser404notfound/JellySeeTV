    "%lld": {
      "comment": "A row that shows the position of an item in the cart and its corresponding icon and name.",
      "isCommentAutoGenerated": true
    },
    "%lld%%": {
      "comment": "A label showing the percentage of a show that the user has watched. The argument is the percentage.",
      "isCommentAutoGenerated": true
    },
    "E%lld": {
      "comment": "A number indicating the episode number.",
      "isCommentAutoGenerated": true
    },
