    "settings.profile.launch.default.detail": {
      "comment": "Explanation under 'Use default profile' option",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přeskočí výběr a automaticky přihlásí výchozí profil."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Spring vælgeren over og log ind som standardprofilen automatisk."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Auswahl überspringen und direkt mit dem Standardprofil anmelden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Παρακάμπτει την επιλογή και συνδέεται αυτόματα με το προεπιλεγμένο προφίλ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Skip the picker and sign in as the default profile automatically."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Omite la selección y accede automáticamente con el perfil predeterminado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ohittaa valitsimen ja kirjautuu sisään oletusprofiililla automaattisesti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignorer le sélecteur et se connecter automatiquement avec le profil par défaut."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Preskače odabir i automatski se prijavljuje kao zadani profil."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Kihagyja a választót és automatikusan bejelentkezik az alapértelmezett profillal."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Salta il selettore ed effettua l'accesso automaticamente con il profilo predefinito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピッカーをスキップして、デフォルトのプロファイルで自動的にサインインします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "선택기를 건너뛰고 기본 프로필로 자동 로그인합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Hopp over velgeren og logg inn som standardprofilen automatisk."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Sla de kiezer over en log automatisch in als het standaardprofiel."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pomiń selektor i zaloguj się automatycznie jako profil domyślny."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Pula o seletor e entra com o perfil padrão automaticamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ignora o seletor e inicia sessão com o perfil predefinido automaticamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Sari peste selector și conectează-te automat cu profilul implicit."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропустить выбор и автоматически войти под профилем по умолчанию."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Preskočiť výber a automaticky prihlásiť predvolený profil."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoppa över väljaren och logga in som standardprofilen automatiskt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Seçiciyi atla ve varsayılan profille otomatik olarak giriş yap."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропустити вибір і автоматично увійти як стандартний профіль."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过选择器,自动使用默认配置文件登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "跳過選擇器,自動使用預設設定檔登入。"
