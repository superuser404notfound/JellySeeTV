    "settings.appearance.subtitle": {
      "comment": "Subtitle on the Appearance screen explaining what the accent color affects",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte zvýrazňovací barvu pro tlačítka, fokusové prstence a zvýraznění."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg en fremhævningsfarve til knapper, fokusringe og fremhævninger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle eine Akzentfarbe für Buttons, Fokusrahmen und Hervorhebungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ένα χρώμα έμφασης για κουμπιά, δαχτυλίδια εστίασης και επισημάνσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick an accent color for buttons, focus rings, and highlights."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un color de acento para botones, anillos de enfoque y resaltados."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse korostusväri painikkeille, kohdistusrenkaille ja korostuksille."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez une couleur d'accent pour les boutons, les anneaux de focus et les surlignages."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite naglasnu boju za gumbe, prstenove fokusa i isticanja."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válassz kiemelőszínt a gombokhoz, fókuszgyűrűkhöz és kiemelésekhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli un colore di accento per pulsanti, anelli di messa a fuoco ed evidenziazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ボタン、フォーカスリング、ハイライトのアクセントカラーを選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "버튼, 포커스 링 및 강조 표시에 사용할 강조 색상을 선택하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg en aksentfarge for knapper, fokusringer og fremhevinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies een accentkleur voor knoppen, focusringen en markeringen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz kolor akcentu dla przycisków, pierścieni fokusu i wyróżnień."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma cor de destaque para botões, anéis de foco e realces."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha uma cor de realce para botões, anéis de foco e destaques."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege o culoare de accent pentru butoane, inele de focalizare și evidențieri."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите акцентный цвет для кнопок, колец фокуса и выделений."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte zvýrazňovaciu farbu pre tlačidlá, fokusové prstence a zvýraznenia."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj en accentfärg för knappar, fokusringar och markeringar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Düğmeler, odak halkaları ve vurgular için bir vurgu rengi seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть акцентний колір для кнопок, кілець фокусу та виділень."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为按钮、焦点环和高亮选择一个强调色。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為按鈕、焦點環和高亮選擇一個強調色。"
          }
        }
      }
    },
