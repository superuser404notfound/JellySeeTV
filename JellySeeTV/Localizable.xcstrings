    "home.customize.description": {
      "comment": "Description in home customize view",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte, které řádky se zobrazí na domovské obrazovce."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg hvilke rækker der vises på din startskærm."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle aus, welche Reihen auf deiner Startseite angezeigt werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ποιες σειρές θα εμφανίζονται στην αρχική οθόνη."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose which rows appear on your home screen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige qué filas aparecen en tu pantalla de inicio."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse, mitkä rivit näkyvät aloitusnäytössä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les lignes à afficher sur votre écran d'accueil."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Odaberite koji retci će se pojaviti na početnom zaslonu."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd ki, mely sorok jelenjenek meg a kezdőképernyőn."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli quali righe mostrare nella schermata iniziale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホーム画面に表示する行を選択します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "홈 화면에 표시할 행을 선택하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg hvilke rader som vises på hjemskjermen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies welke rijen op je startscherm verschijnen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz, które wiersze mają się pojawiać na ekranie głównym."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha quais linhas aparecem na tela inicial."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha que linhas aparecem no ecrã inicial."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege ce rânduri apar pe ecranul principal."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите строки для главного экрана."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte, ktoré riadky sa zobrazia na domovskej obrazovke."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj vilka rader som visas på hemskärmen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana ekranınızda hangi satırların görüneceğini seçin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть, які рядки з'являться на головному екрані."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
