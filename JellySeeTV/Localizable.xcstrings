    "settings.playback.autoSubtitleForeign.subtitle": {
      "comment": "Subtitle for the autoSubtitleForeign preference",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Automaticky zobrazit titulky, pokud přehrávaný zvuk není ve vašem preferovaném jazyce."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
