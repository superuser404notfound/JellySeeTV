    "support.pending": {
      "comment": "Status banner when a purchase is pending parental approval or SCA",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Čeká se na schválení. Nákup bude dokončen po schválení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Afventer godkendelse. Købet afsluttes, når det er godkendt."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Warten auf Freigabe. Der Kauf wird abgeschlossen, sobald er genehmigt ist."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Αναμονή για έγκριση. Η αγορά θα ολοκληρωθεί μόλις εγκριθεί."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Waiting for approval. The purchase will complete once approved."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esperando aprobación. La compra se completará una vez aprobada."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Odotetaan hyväksyntää. Osto viimeistellään, kun se on hyväksytty."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En attente d'approbation. L'achat sera finalisé une fois approuvé."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Čeka se odobrenje. Kupnja će biti dovršena nakon odobrenja."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jóváhagyásra várva. A vásárlás jóváhagyás után fejeződik be."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "In attesa di approvazione. L'acquisto sarà completato una volta approvato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "承認待ちです。承認後、購入が完了します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "승인 대기 중. 승인되면 구매가 완료됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Venter på godkjenning. Kjøpet fullføres når det er godkjent."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wachten op goedkeuring. De aankoop wordt voltooid na goedkeuring."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oczekiwanie na zatwierdzenie. Zakup zostanie zakończony po zatwierdzeniu."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguardando aprovação. A compra será concluída após a aprovação."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A aguardar aprovação. A compra será concluída após a aprovação."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Se așteaptă aprobarea. Achiziția se va finaliza după aprobare."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ожидание подтверждения. Покупка будет завершена после подтверждения."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Čaká sa na schválenie. Nákup sa dokončí po schválení."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Väntar på godkännande. Köpet slutförs när det är godkänt."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Onay bekleniyor. Satın alma onaylandığında tamamlanacak."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Очікування схвалення. Покупку буде завершено після схвалення."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "等待批准。批准后购买将完成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "等待批准。批准後購買將完成。"
          }
        }
      }
