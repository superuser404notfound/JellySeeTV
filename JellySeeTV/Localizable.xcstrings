    "profile.forget.message": {
      "comment": "Explanatory text under the forget-profile confirm dialog",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Při příštím výběru tohoto profilu se budete muset znovu přihlásit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du skal logge ind igen næste gang du vælger denne profil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du musst dich erneut anmelden, wenn du dieses Profil das nächste Mal auswählst."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Θα χρειαστεί να συνδεθείτε ξανά την επόμενη φορά που θα επιλέξετε αυτό το προφίλ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You'll need to sign in again the next time you pick this profile."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tendrás que iniciar sesión de nuevo la próxima vez que elijas este perfil."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sinun täytyy kirjautua uudelleen sisään, kun valitset tämän profiilin seuraavan kerran."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous devrez vous reconnecter la prochaine fois que vous choisirez ce profil."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Morat ćete se ponovno prijaviti sljedeći put kad odaberete ovaj profil."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A profil következő kiválasztásakor újra be kell jelentkezned."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dovrai accedere di nuovo la prossima volta che scegli questo profilo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "次回このプロファイルを選ぶときは、再度サインインが必要です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 프로필을 다시 선택할 때 다시 로그인해야 합니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du må logge inn på nytt neste gang du velger denne profilen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je moet opnieuw inloggen de volgende keer dat je dit profiel kiest."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Następnym razem po wybraniu tego profilu trzeba będzie zalogować się ponownie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você precisará entrar novamente na próxima vez que escolher este perfil."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Terá de iniciar sessão novamente da próxima vez que escolher este perfil."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Va trebui să te conectezi din nou data viitoare când alegi acest profil."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При следующем выборе этого профиля потребуется войти заново."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pri ďalšom výbere tohto profilu sa budete musieť znova prihlásiť."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du måste logga in igen nästa gång du väljer den här profilen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu profili bir dahaki sefere seçtiğinde tekrar oturum açman gerekecek."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вам доведеться ввійти знову, коли наступного разу виберете цей профіль."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "下次选择此配置文件时需要重新登录。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "下次選擇此設定檔時需要重新登入。"
          }
        }
      }
    },
