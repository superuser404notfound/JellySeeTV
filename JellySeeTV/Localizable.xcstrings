    "settings.profile.switchTo.hint": {
      "comment": "Hint under switch-profile grid",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Klepnutím přepnete bez opětovného přihlášení. Dlouhým stisknutím odstraníte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryk for at skifte uden at logge ind igen. Hold nede for at fjerne."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippen zum Wechseln ohne erneute Anmeldung. Langer Druck zum Entfernen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πατήστε για εναλλαγή χωρίς νέα σύνδεση. Παρατεταμένο πάτημα για αφαίρεση."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to switch without signing in again. Long-press to remove."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca para cambiar sin iniciar sesión de nuevo. Mantén pulsado para eliminar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaihda napauttamalla ilman uudelleenkirjautumista. Poista pitkällä painalluksella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez pour changer sans vous reconnecter. Maintenez pour supprimer."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodirnite za promjenu bez ponovne prijave. Dugo pritisnite za uklanjanje."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Érintsd meg a váltáshoz újrabejelentkezés nélkül. Hosszú nyomás az eltávolításhoz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca per cambiare senza accedere di nuovo. Premi a lungo per rimuovere."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "タップで再サインインなしに切り替え。長押しで削除。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "탭하면 다시 로그인 없이 전환됩니다. 길게 누르면 제거됩니다."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Trykk for å bytte uten å logge inn på nytt. Hold nede for å fjerne."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tik om te wisselen zonder opnieuw in te loggen. Houd ingedrukt om te verwijderen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dotknij, aby przełączyć bez ponownego logowania. Przytrzymaj, aby usunąć."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque para trocar sem entrar de novo. Pressione e segure para remover."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque para mudar sem iniciar sessão novamente. Mantenha premido para remover."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Atinge pentru a schimba fără a te conecta din nou. Apasă lung pentru a elimina."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Коснитесь, чтобы переключиться без повторного входа. Удерживайте, чтобы удалить."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Klepnutím prepnete bez opätovného prihlásenia. Dlhým stlačením odstránite."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Tryck för att byta utan att logga in igen. Håll nedtryckt för att ta bort."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tekrar giriş yapmadan değiştirmek için dokunun. Kaldırmak için uzun basın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Торкніться, щоб переключитися без повторного входу. Утримуйте, щоб видалити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按即可切换,无需再次登录。长按可移除。"
          }
        },
