    "support.pack.subtitle": {
      "comment": "Subtitle explaining what the Supporter Pack unlocks",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorázové odemčení. Kosmetické extra — speciální úvodní ikona, vlastní zvýrazňovací barvy a odznak podporovatele v nastavení."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Engangsoplåsning. Kosmetiske ekstras — et specielt splash-ikon, brugerdefinerede fremhævningsfarver og et supporter-badge i Indstillinger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einmaliger Freischaltkauf. Kosmetische Extras — ein spezielles Splash-Icon, eigene Akzentfarben und ein Supporter-Abzeichen in den Einstellungen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Εφάπαξ ξεκλείδωμα. Κοσμητικά έξτρα — ένα ειδικό εικονίδιο έναρξης, προσαρμοσμένα χρώματα έμφασης και ένα σήμα υποστηρικτή στις Ρυθμίσεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "One-time unlock. Cosmetic extras — a special splash icon, custom accent colors, and a supporter badge in Settings."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueo único. Extras cosméticos: un icono de inicio especial, colores de acento personalizados y una insignia de apoyo en Ajustes."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kertakertainen avaus. Kosmeettiset lisät — erityinen käynnistyskuvake, mukautetut korostusvärit ja tukija-merkki asetuksissa."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Déblocage unique. Extras cosmétiques — une icône de lancement spéciale, des couleurs d'accent personnalisées et un badge de soutien dans les Réglages."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednokratno otključavanje. Kozmetički dodaci — posebna uvodna ikona, prilagođene naglasne boje i podržavateljska značka u postavkama."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Egyszeri feloldás. Kozmetikai extrák — egy különleges nyitóikon, egyéni kiemelőszínek és egy támogatói jelvény a Beállításokban."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocco una tantum. Extra estetici — un'icona iniziale speciale, colori di accento personalizzati e un badge sostenitore in Impostazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一回限りのアンロック。コスメティックエクストラ — 特別なスプラッシュアイコン、カスタムアクセントカラー、設定内のサポーターバッジ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일회성 잠금 해제. 꾸미기 추가 기능 — 특별한 스플래시 아이콘, 맞춤 강조 색상, 설정의 서포터 배지."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Engangsopplåsing. Kosmetiske ekstra — et spesielt splash-ikon, tilpassede aksentfarger og et supporter-merke i Innstillinger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Eenmalige ontgrendeling. Cosmetische extra's — een speciaal splash-icoon, aangepaste accentkleuren en een supportersbadge in Instellingen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorazowe odblokowanie. Dodatki kosmetyczne — specjalna ikona powitalna, niestandardowe kolory akcentu i odznaka wspierającego w Ustawieniach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueio único. Extras cosméticos — um ícone de abertura especial, cores de destaque personalizadas e um distintivo de apoiador nos Ajustes."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueio único. Extras cosméticos — um ícone de abertura especial, cores de realce personalizadas e um distintivo de apoiante nas Definições."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deblocare unică. Extra cosmetice — o pictogramă de pornire specială, culori de accent personalizate și o insignă de susținător în Setări."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разовая разблокировка. Косметические дополнения — специальная заставка, настраиваемые акцентные цвета и значок поддержки в настройках."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Jednorazové odomknutie. Kozmetické extra — špeciálna úvodná ikona, vlastné zvýrazňovacie farby a odznak podporovateľa v nastaveniach."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Engångsupplåsning. Kosmetiska extra — en speciell startikon, anpassade accentfärger och ett supporter-märke i Inställningar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tek seferlik kilit açma. Kozmetik ekstralar — özel bir açılış simgesi, özel vurgu renkleri ve Ayarlar'da bir destekçi rozeti."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Разове розблокування. Косметичні доповнення — спеціальна заставка, власні акцентні кольори та значок прихильника в налаштуваннях."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性解锁。装饰性附加内容 — 特殊启动图标、自定义强调色和设置中的支持者徽章。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一次性解鎖。裝飾性附加內容 — 特殊啟動圖示、自訂強調色和設定中的支持者徽章。"
          }
        }
      }
    },
    "support.pack.thanks": {
      "comment": "Status banner after purchasing the Supporter Pack",
      "extractionState": "manual",
      "localizations": {
