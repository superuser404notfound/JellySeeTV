    "settings.seerr.description": {
      "comment": "Settings description",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Připojte Seerr k procházení oblíbeného obsahu a žádání o nové filmy nebo seriály."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Forbind Seerr for at gennemse populært indhold og anmode om nye film eller serier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbinde Seerr, um beliebte Inhalte zu entdecken und neue Filme oder Serien anzufordern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Συνδέστε το Seerr για να περιηγηθείτε σε δημοφιλές περιεχόμενο και να ζητήσετε νέες ταινίες ή σειρές."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect Seerr to browse popular content and request new movies or shows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta Seerr para explorar contenido popular y solicitar nuevas películas o series."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Yhdistä Seerr selataksesi suosittua sisältöä ja pyytääksesi uusia elokuvia tai sarjoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez Seerr pour parcourir les contenus populaires et demander de nouveaux films ou séries."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Povežite Seerr za pregledavanje popularnog sadržaja i zahtijevanje novih filmova ili serija."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Csatlakoztasd a Seerr-t a népszerű tartalmak böngészéséhez és új filmek vagy sorozatok kéréséhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Collega Seerr per sfogliare i contenuti popolari e richiedere nuovi film o serie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Seerr に接続すると、人気コンテンツを閲覧したり、新しい映画や番組をリクエストできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Seerr에 연결하여 인기 콘텐츠를 둘러보고 새 영화나 프로그램을 요청하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Koble til Seerr for å bla gjennom populært innhold og be om nye filmer eller serier."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Verbind Seerr om populaire content te bekijken en nieuwe films of series aan te vragen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Połącz Seerr, aby przeglądać popularne treści i prosić o nowe filmy lub seriale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecte o Seerr para navegar por conteúdo popular e solicitar novos filmes ou séries."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligue o Seerr para explorar conteúdo popular e pedir novos filmes ou séries."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectează Seerr pentru a răsfoi conținut popular și a solicita noi filme sau seriale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подключите Seerr, чтобы просматривать популярный контент и запрашивать новые фильмы или сериалы."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Pripojte Seerr na prehliadanie obľúbeného obsahu a žiadanie o nové filmy alebo seriály."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslut Seerr för att bläddra bland populärt innehåll och begära nya filmer eller serier."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Popüler içeriklere göz atmak ve yeni filmler veya diziler istemek için Seerr'i bağlayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підключіть Seerr, щоб переглядати популярний контент і запитувати нові фільми чи серіали."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "连接 Seerr 以浏览热门内容并请求新的电影或剧集。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連接 Seerr 以瀏覽熱門內容並請求新的電影或影集。"
          }
        }
      }
    },
