    "support.unavailable.subtitle": {
      "comment": "Explainer under the unavailable card pointing to sandbox testing",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přihlaste se pomocí testovacího účtu Sandbox nebo počkejte na schválení nákupů od Applu. Klepnutím obnovit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Log ind med en Sandbox Tester-konto, eller vent på, at Apple godkender in-app-købene. Tryk for at prøve igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Melde dich mit einem Sandbox-Tester-Account an oder warte, bis Apple die In-App-Käufe prüft. Zum erneuten Versuchen tippen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Συνδεθείτε με λογαριασμό Sandbox Tester ή περιμένετε να εγκρίνει η Apple τις αγορές εντός εφαρμογής. Πατήστε για επανάληψη."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in with a Sandbox Tester account or wait for Apple to approve the in-app purchases. Tap to retry."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicia sesión con una cuenta Sandbox Tester o espera a que Apple apruebe las compras dentro de la app. Toca para reintentar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjaudu sisään Sandbox Tester -tilillä tai odota, että Apple hyväksyy sovelluksen sisäiset ostot. Napauta yrittääksesi uudelleen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez-vous avec un compte Sandbox Tester ou attendez qu'Apple approuve les achats intégrés. Appuyez pour réessayer."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Prijavite se putem Sandbox Tester računa ili pričekajte da Apple odobri kupnje unutar aplikacije. Dodirnite za ponovni pokušaj."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Jelentkezz be Sandbox Tester fiókkal, vagy várj, amíg az Apple jóváhagyja az alkalmazáson belüli vásárlásokat. Érints a próbálkozáshoz."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Accedi con un account Sandbox Tester o attendi che Apple approvi gli acquisti in-app. Tocca per riprovare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サンドボックステスターアカウントでサインインするか、Appleがアプリ内課金を承認するのを待ってください。タップして再試行。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Sandbox Tester 계정으로 로그인하거나 Apple이 인앱 구매를 승인할 때까지 기다리세요. 다시 시도하려면 탭하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Logg inn med en Sandbox Tester-konto, eller vent på at Apple godkjenner kjøpene i appen. Trykk for å prøve igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Meld je aan met een Sandbox Tester-account of wacht tot Apple de in-app aankopen goedkeurt. Tik om opnieuw te proberen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaloguj się za pomocą konta Sandbox Tester lub poczekaj, aż Apple zatwierdzi zakupy w aplikacji. Dotknij, aby ponowić."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Entre com uma conta Sandbox Tester ou aguarde a Apple aprovar as compras no app. Toque para tentar novamente."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Inicie sessão com uma conta Sandbox Tester ou aguarde que a Apple aprove as compras na app. Toque para tentar novamente."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Conectează-te cu un cont Sandbox Tester sau așteaptă ca Apple să aprobe achizițiile din aplicație. Atinge pentru a reîncerca."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Войдите с аккаунтом Sandbox Tester или дождитесь одобрения встроенных покупок от Apple. Коснитесь, чтобы повторить."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Prihláste sa pomocou účtu Sandbox Tester alebo počkajte na schválenie nákupov od Applu. Klepnutím obnovíte."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Logga in med ett Sandbox Tester-konto eller vänta på att Apple godkänner app-köpen. Tryck för att försöka igen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sandbox Tester hesabıyla oturum aç veya Apple'ın uygulama içi satın almaları onaylamasını bekle. Yeniden denemek için dokun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увійдіть за допомогою облікового запису Sandbox Tester або зачекайте, поки Apple схвалить покупки в додатку. Торкніться, щоб повторити."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Sandbox Tester 账户登录，或等待 Apple 审核应用内购买。点按重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用 Sandbox Tester 帳號登入，或等待 Apple 審核應用內購買。點按重試。"
          }
        }
      }
    },
