    "catalog.empty.noServer.description": {
      "comment": "Instruction text when Seerr not configured",
      "extractionState": "manual",
      "localizations": {
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte Seerr v Nastavení, abyste mohli procházet a žádat o nové filmy a seriály."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurer Seerr i Indstillinger for at gennemse og anmode om nye film og serier."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Richte Seerr in den Einstellungen ein, um neue Filme und Serien zu entdecken und anzufordern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ρυθμίστε το Seerr στις Ρυθμίσεις για να περιηγηθείτε και να ζητήσετε νέες ταινίες και σειρές."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set up Seerr in Settings to browse and request new movies and shows."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura Seerr en Ajustes para explorar y solicitar nuevas películas y series."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Määritä Seerr asetuksissa selataksesi ja pyytääksesi uusia elokuvia ja sarjoja."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurez Seerr dans les Réglages pour parcourir et demander de nouveaux films et séries."
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Postavite Seerr u Postavkama za pregledavanje i zahtijevanje novih filmova i serija."
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Állítsd be a Seerr-t a Beállításokban új filmek és sorozatok böngészéséhez és kéréséhez."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Configura Seerr nelle Impostazioni per sfogliare e richiedere nuovi film e serie."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定で Seerr をセットアップして、新しい映画や番組を閲覧・リクエストできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정에서 Seerr를 구성하여 새 영화와 프로그램을 탐색하고 요청하세요."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Sett opp Seerr i Innstillinger for å bla gjennom og be om nye filmer og serier."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stel Seerr in bij Instellingen om nieuwe films en series te bekijken en aan te vragen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Skonfiguruj Seerr w Ustawieniach, aby przeglądać i prosić o nowe filmy oraz seriale."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure o Seerr em Configurações para navegar e solicitar novos filmes e séries."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure o Seerr nas Definições para explorar e pedir novos filmes e séries."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Configurează Seerr în Setări pentru a răsfoi și solicita noi filme și seriale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте Seerr в настройках, чтобы просматривать и запрашивать новые фильмы и сериалы."
          }
        },
        "sk": {
          "stringUnit": {
            "state": "translated",
            "value": "Nastavte Seerr v Nastaveniach, aby ste mohli prehliadať a žiadať o nové filmy a seriály."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurera Seerr i Inställningar för att bläddra bland och begära nya filmer och serier."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni filmlere ve dizilere göz atmak ve istekte bulunmak için Ayarlar'da Seerr'i kurun."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштуйте Seerr у Параметрах, щоб переглядати та запитувати нові фільми й серіали."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置中配置 Seerr,以便浏览并请求新的电影和剧集。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在「設定」中設定 Seerr,以瀏覽並請求新的電影與影集。"
          }
        }
      }
    },
